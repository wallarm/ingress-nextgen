# Source: wallarm-ingress/templates/controller-hpa.yaml
apiVersion: autoscaling/v2
kind: HorizontalPodAutoscaler
metadata:
  name: deployment-hpa-wallarm-ingress-controller
  namespace: default
  labels:
    helm.sh/chart: wallarm-ingress-CHART_VERSION
    app.kubernetes.io/name: wallarm-ingress
    app.kubernetes.io/instance: deployment-hpa
    app.kubernetes.io/version: "APP_VERSION"
    app.kubernetes.io/managed-by: Helm
spec:
  scaleTargetRef:
    apiVersion: apps/v1
    kind: Deployment
    name: deployment-hpa-wallarm-ingress-controller
  minReplicas: 1
  maxReplicas: 3
  metrics:
    - type: Resource
      resource:
        name: memory
        target:
          type: Utilization
          averageUtilization: 50
    - type: Resource
      resource:
        name: cpu
        target:
          type: Utilization
          averageUtilization: 50
