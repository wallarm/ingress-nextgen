          value: www-data
        - name: WALLARM_LABELS
          value: "group=us-production"
        volumeMounts:
        - mountPath: /opt/wallarm/etc/wallarm
          name: wallarm
        - mountPath: /opt/wallarm/var/lib/wallarm-acl
          name: wallarm-acl
        - mountPath: /opt/wallarm/var/lib/wallarm-api
          name: wallarm-apifw
        - mountPath: /secrets/wallarm/token
          name: wallarm-token
          subPath: token
          readOnly: true
        
        securityContext:
          allowPrivilegeEscalation: false
          readOnlyRootFilesystem: false
          runAsUser: 101 #nginx
          runAsNonRoot: true
          capabilities:
            drop:
            - ALL
            add:
            - NET_BIND_SERVICE
      containers:
        
        - name: wcli
          image: docker.io/wallarm/node-helpers:APP_VERSION
          imagePullPolicy: IfNotPresent
          args: ["wcli", "run", "-log-level", "WARN", "job:blkexp", "-log-level", "INFO", "job:botexp", "-log-level", "WARN", "job:cntexp", "-log-level", "ERROR", "job:cntsync", "-log-level", "INFO", "job:credstuff", "-log-level", "INFO", "job:envexp", "-log-level", "INFO", "job:jwtexp", "-log-level", "INFO", "job:mrksync", "-log-level", "INFO", "job:register", "-log-level", "INFO", "job:reqexp", "-log-level", "INFO"]
          env:
          - name: WALLARM_API_HOST
            value: "us1.api.wallarm.com"
          - name: WALLARM_API_PORT
            value: "443"
          - name: WALLARM_API_USE_SSL
            value: "true"
          - name: WALLARM_API_TOKEN_PATH
            value: "/secrets/wallarm/token"
          - name: WALLARM_COMPONENT_NAME
            value: wallarm-new-ingress-controller
          - name: WALLARM_COMPONENT_VERSION
            value: "CHART_VERSION"
          - name: WALLARM_NODE_NAME
            valueFrom:
              fieldRef:
                fieldPath: metadata.name
          - name: WALLARM_WCLI__METRICS__LISTEN_ADDRESS
            value: ":9003"
          ports:
          - name: wcli-post-mtrc
            containerPort: 9003
            protocol: TCP
          volumeMounts:
          - mountPath: /opt/wallarm/etc/wallarm
            name: wallarm
          - mountPath: /opt/wallarm/var/lib/wallarm-acl
            name: wallarm-acl
          - mountPath: /secrets/wallarm/token
            name: wallarm-token
            subPath: token
            readOnly: true
          
          securityContext:
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: false
            runAsUser: 101 #nginx
            runAsNonRoot: true
            capabilities:
              drop:
              - ALL
              add:
              - NET_BIND_SERVICE
        - name: wstore
          image: docker.io/wallarm/node-helpers:APP_VERSION
          imagePullPolicy: IfNotPresent
          args: ["wstore"]
          env:
            
            - name: SLAB_ALLOC_ARENA
              value: "2.0"
            - name: WALLARM_WSTORE__METRICS__LISTEN_ADDRESS
              value: "127.0.0.1:9001"
            - name: WALLARM_WSTORE__METRICS__PROTOCOL
              value: "tcp4"
            - name: WALLARM_WSTORE__SERVICE__ADDRESS
              value: "0.0.0.0:3313"
            - name: WALLARM_WSTORE__SERVICE__PROTOCOL
              value: "tcp4"
          ports:
          - name: wstore
            containerPort: 3313
            protocol: TCP
          volumeMounts:
          - name: wallarm
            mountPath: /opt/wallarm/etc/wallarm
          livenessProbe:
            httpGet:
              path: /health
              port: 5005
            initialDelaySeconds: 5
            periodSeconds: 10
            timeoutSeconds: 1
            successThreshold: 1
            failureThreshold: 3
          readinessProbe:
            httpGet:
              path: /health
              port: 5005
            initialDelaySeconds: 5
            periodSeconds: 10
            timeoutSeconds: 1
            successThreshold: 1
            failureThreshold: 3
          
          securityContext:
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: false
            runAsUser: 101 #nginx
            runAsNonRoot: true
            capabilities:
              drop:
              - ALL
              add:
              - NET_BIND_SERVICE
        - name: wallarm-appstructure
          image: docker.io/wallarm/node-helpers:APP_VERSION
          imagePullPolicy: IfNotPresent
          args: ["appstructure"]
          volumeMounts:
          - name: wallarm
            mountPath: /opt/wallarm/etc/wallarm
          
          securityContext:
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: false
            runAsUser: 101 #nginx
            runAsNonRoot: true
            capabilities:
              drop:
              - ALL
              add:
              - NET_BIND_SERVICE
      volumes:
      - name: wallarm
        emptyDir: {}
      - name: wallarm-acl
        emptyDir: {}
      - name: wallarm-apifw
        emptyDir: {}
      - name: wallarm-token
        secret:
          secretName: wallarm-us-cloud-wallarm-ingress-wallarm-token
          items:
            - key: token
              path: token
