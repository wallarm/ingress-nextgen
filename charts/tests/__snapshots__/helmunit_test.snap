# Source: wallarm-ingress-new/templates/controller-daemonset.yaml
apiVersion: apps/v1
kind: DaemonSet
metadata:
  name: daemonset-wallarm-ingress-new-controller
  namespace: default
  labels:
    helm.sh/chart: wallarm-ingress-new-7.0.0
    app.kubernetes.io/name: wallarm-ingress-new
    app.kubernetes.io/instance: daemonset
    app.kubernetes.io/version: "6.7.5"
    app.kubernetes.io/managed-by: Helm
    app.kubernetes.io/component: controller
spec:
  selector:
    matchLabels:
      app.kubernetes.io/name: wallarm-ingress-new
      app.kubernetes.io/instance: daemonset
      app.kubernetes.io/component: controller
  template:
    metadata:
      labels:
        app.kubernetes.io/name: wallarm-ingress-new
        app.kubernetes.io/instance: daemonset
        app.kubernetes.io/component: controller
      annotations:
        prometheus.io/scrape: "true"
        prometheus.io/port: "9113"
        prometheus.io/scheme: "http"
    spec:
      serviceAccountName: daemonset-wallarm-ingress-new
      automountServiceAccountToken: true
      securityContext:
        seccompProfile:
          type: RuntimeDefault
      terminationGracePeriodSeconds: 30      
      volumes: []
      hostNetwork: false
      dnsPolicy: ClusterFirst
      containers:
      - name: wallarm-ingress-new
        image: docker.io/wallarm/nginx-node-ic:0.0.1
        imagePullPolicy: "IfNotPresent"
        ports:
        - name: http
          containerPort: 80
          protocol: TCP
        - name: https
          containerPort: 443
          protocol: TCP

        - name: prometheus
          containerPort: 9113
        - name: readiness-port
          containerPort: 8081
        readinessProbe:
          httpGet:
            path: /nginx-ready
            port: readiness-port
          periodSeconds: 1
          initialDelaySeconds: 0
        securityContext:
          allowPrivilegeEscalation: false
          readOnlyRootFilesystem: false
          runAsUser: 101 #nginx
          runAsNonRoot: true
          capabilities:
            drop:
            - ALL
            add:
            - NET_BIND_SERVICE        
        volumeMounts: []
        env:
        - name: POD_NAMESPACE
          valueFrom:
            fieldRef:
              fieldPath: metadata.namespace
        - name: POD_NAME
          valueFrom:
            fieldRef:
              fieldPath: metadata.name
        resources:
          requests:
            cpu: 100m
            memory: 128Mi
        args:
          
          - -nginx-reload-timeout=60000
          - -nginx-configmaps=$(POD_NAMESPACE)/daemonset-wallarm-ingress-new
          - -ingress-class=nginx
          - -health-status=false
          - -health-status-uri=/nginx-health
          - -nginx-debug=false
          - -log-level=info
          - -log-format=glog
          - -nginx-status=true
          - -nginx-status-port=10246
          - -nginx-status-allow-cidrs=127.0.0.1
          - -report-ingress-status
          - -external-service=daemonset-wallarm-ingress-new-controller
          - -enable-leader-election=true
          - -leader-election-lock-name=daemonset-wallarm-ingress-new-leader-election
          - -enable-prometheus-metrics=true
          - -prometheus-metrics-listen-port=9113
          - -prometheus-tls-secret=
          - -enable-custom-resources=true
          - -enable-snippets=false
          - -disable-ipv6=false
          - -enable-tls-passthrough=false
          - -enable-cert-manager=false
          - -enable-external-dns=false
          - -default-http-listener-port=80
          - -default-https-listener-port=443
          - -ready-status=true
          - -ready-status-port=8081
          - -enable-latency-metrics=false
          - -ssl-dynamic-reload=true
          - -enable-telemetry-reporting=false
/-/-/-/
