    targetPort: 80
    protocol: TCP
    name: http
    nodePort: 
  - port: 443
    targetPort: 443
    protocol: TCP
    name: https
    nodePort: 
  selector:
    app.kubernetes.io/name: wallarm-ingress
    app.kubernetes.io/instance: app-protect-wafv5-agentv2
    app.kubernetes.io/component: controller
