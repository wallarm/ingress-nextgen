# Source: wallarm-ingress-new/templates/controller-service.yaml
apiVersion: v1
kind: Service
metadata:
  name: plus-mgmt-custom-endpoint-wallarm-ingress-new-controller
  namespace: default
  labels:
    helm.sh/chart: wallarm-ingress-new-7.0.0
    app.kubernetes.io/name: wallarm-ingress-new
    app.kubernetes.io/instance: plus-mgmt-custom-endpoint
    app.kubernetes.io/version: "6.7.5"
    app.kubernetes.io/managed-by: Helm
    app.kubernetes.io/component: controller
spec:
  externalTrafficPolicy: Local
  type: LoadBalancer
  ports:
  - port: 80
    targetPort: 80
    protocol: TCP
    name: http
    nodePort: 
  - port: 443
    targetPort: 443
    protocol: TCP
    name: https
    nodePort: 
  selector:
    app.kubernetes.io/name: wallarm-ingress-new
    app.kubernetes.io/instance: plus-mgmt-custom-endpoint
    app.kubernetes.io/component: controller
