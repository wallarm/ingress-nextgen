kind: RoleBinding
apiVersion: rbac.authorization.k8s.io/v1
metadata:
  name: oss-agent-wallarm-ingress-new
  labels:
    helm.sh/chart: wallarm-ingress-new-7.0.0
    app.kubernetes.io/name: wallarm-ingress-new
    app.kubernetes.io/instance: oss-agent
    app.kubernetes.io/version: "6.7.5"
    app.kubernetes.io/managed-by: Helm
  namespace: default
roleRef:
  apiGroup: rbac.authorization.k8s.io
