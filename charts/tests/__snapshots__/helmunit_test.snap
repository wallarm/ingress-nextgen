# Source: wallarm-ingress/templates/controller-deployment.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: global-config-custom-name-wallarm-ingress-controller
  namespace: default
  labels:
    helm.sh/chart: wallarm-ingress-CHART_VERSION
    app.kubernetes.io/name: wallarm-ingress
    app.kubernetes.io/instance: global-config-custom-name
    app.kubernetes.io/version: "APP_VERSION"
    app.kubernetes.io/managed-by: Helm
    app.kubernetes.io/component: controller
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: wallarm-ingress
      app.kubernetes.io/instance: global-config-custom-name
      app.kubernetes.io/component: controller
  template:
    metadata:
      labels:
        app.kubernetes.io/name: wallarm-ingress
        app.kubernetes.io/instance: global-config-custom-name
        app.kubernetes.io/version: "APP_VERSION"
        app.kubernetes.io/component: controller
      annotations:
        prometheus.io/scrape: "true"
        prometheus.io/port: "9113"
        prometheus.io/scheme: "http"
    spec:      
      volumes: []
      serviceAccountName: global-config-custom-name-wallarm-ingress
      automountServiceAccountToken: true
      securityContext:
        seccompProfile:
          type: RuntimeDefault
      terminationGracePeriodSeconds: 30
      hostNetwork: false
      dnsPolicy: ClusterFirst
      containers:
      - image: docker.io/wallarm/ingress-controller:CHART_VERSION
        name: wallarm-ingress
        imagePullPolicy: "IfNotPresent"
        ports:
        - name: http
          containerPort: 80
          protocol: TCP
        - name: https
          containerPort: 443
          protocol: TCP
        - name: prometheus
          containerPort: 9113
        - name: readiness-port
          containerPort: 8081
        readinessProbe:
          httpGet:
            path: /nginx-ready
            port: readiness-port
          periodSeconds: 1
          initialDelaySeconds: 0
        resources:
          requests:
            cpu: 100m
            memory: 128Mi
        securityContext:
          allowPrivilegeEscalation: false
          readOnlyRootFilesystem: false
          runAsUser: 101 #nginx
          runAsNonRoot: true
          capabilities:
            drop:
            - ALL
            add:
            - NET_BIND_SERVICE        
        volumeMounts: []
        env:
        - name: POD_NAMESPACE
          valueFrom:
            fieldRef:
              fieldPath: metadata.namespace
        - name: POD_NAME
          valueFrom:
            fieldRef:
              fieldPath: metadata.name
        args:
          
          - -nginx-reload-timeout=60000
          - -nginx-configmaps=$(POD_NAMESPACE)/global-config-custom-name-wallarm-ingress
          - -ingress-class=nginx
          - -health-status=false
          - -health-status-uri=/nginx-health
          - -nginx-debug=false
          - -log-level=info
          - -log-format=glog
          - -nginx-status=true
          - -nginx-status-port=10246
          - -nginx-status-allow-cidrs=127.0.0.1
          - -report-ingress-status
          - -external-service=global-config-custom-name-wallarm-ingress-controller
          - -enable-leader-election=true
          - -leader-election-lock-name=global-config-custom-name-wallarm-ingress-leader-election
          - -enable-prometheus-metrics=true
          - -prometheus-metrics-listen-port=9113
          - -prometheus-tls-secret=
          - -enable-custom-resources=true
          - -enable-snippets=false
          - -disable-ipv6=false
          - -enable-tls-passthrough=false
          - -enable-cert-manager=false
          - -enable-external-dns=false
          - -default-http-listener-port=80
          - -default-https-listener-port=443
          - -global-configuration=test-namespace/my-custom-global-config
          - -ready-status=true
          - -ready-status-port=8081
          - -enable-latency-metrics=false
          - -ssl-dynamic-reload=true
          - -enable-telemetry-reporting=false
/-/-/-/
