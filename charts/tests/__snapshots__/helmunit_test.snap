# Source: wallarm-ingress/templates/controller-deployment.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: wallarm-existing-secret-wallarm-ingress-controller
  namespace: default
  labels:
    helm.sh/chart: wallarm-ingress-CHART_VERSION
    app.kubernetes.io/name: wallarm-ingress
    app.kubernetes.io/instance: wallarm-existing-secret
    app.kubernetes.io/version: "APP_VERSION"
    app.kubernetes.io/managed-by: Helm
    app.kubernetes.io/component: controller
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: wallarm-ingress
      app.kubernetes.io/instance: wallarm-existing-secret
      app.kubernetes.io/component: controller
  template:
    metadata:
      labels:
        app.kubernetes.io/name: wallarm-ingress
        app.kubernetes.io/instance: wallarm-existing-secret
        app.kubernetes.io/version: "APP_VERSION"
        app.kubernetes.io/component: controller
      annotations:
        wallarm-enabled: "true"
        prometheus.io/scrape: "true"
        prometheus.io/port: "9113"
        prometheus.io/scheme: "http"
    spec:      
      volumes:
      
      - name: wallarm
        emptyDir: {}
      - name: wallarm-acl
        emptyDir: {}
      - name: wallarm-cache
        emptyDir: {}
      - name: wallarm-token
        secret:
          secretName: my-wallarm-secret
          items:
            - key: api-token
              path: api-token
      - name: wallarm-apifw
        emptyDir: {}
      serviceAccountName: wallarm-existing-secret-wallarm-ingress
      automountServiceAccountToken: true
      securityContext:
        seccompProfile:
          type: RuntimeDefault
      terminationGracePeriodSeconds: 30
      hostNetwork: false
      dnsPolicy: ClusterFirst
      containers:
      - image: docker.io/wallarm/ingress-controller:CHART_VERSION
        name: wallarm-ingress
        imagePullPolicy: "IfNotPresent"
        ports:
        - name: http
          containerPort: 80
          protocol: TCP
        - name: https
          containerPort: 443
          protocol: TCP
        - name: prometheus
          containerPort: 9113
        - name: readiness-port
          containerPort: 8081
        readinessProbe:
          httpGet:
            path: /nginx-ready
            port: readiness-port
          periodSeconds: 1
          initialDelaySeconds: 0
        resources:
          requests:
            cpu: 100m
            memory: 128Mi
        securityContext:
          allowPrivilegeEscalation: false
          readOnlyRootFilesystem: false
          runAsUser: 101 #nginx
          runAsNonRoot: true
          capabilities:
            drop:
            - ALL
            add:
            - NET_BIND_SERVICE        
        volumeMounts:
        
        - name: wallarm
          mountPath: /opt/wallarm/etc/wallarm
        - name: wallarm-acl
          mountPath: /opt/wallarm/var/lib/wallarm-acl
        - name: wallarm-cache
          mountPath: /opt/wallarm/var/lib/nginx/wallarm
        - name: wallarm-apifw
          mountPath: /opt/wallarm/var/lib/wallarm-api
        env:
        - name: POD_NAMESPACE
          valueFrom:
            fieldRef:
              fieldPath: metadata.namespace
        - name: POD_NAME
          valueFrom:
            fieldRef:
              fieldPath: metadata.name
        args:
          
          - -nginx-reload-timeout=60000
          - -nginx-configmaps=$(POD_NAMESPACE)/wallarm-existing-secret-wallarm-ingress
          - -ingress-class=nginx
          - -health-status=false
          - -health-status-uri=/nginx-health
          - -nginx-debug=false
          - -log-level=info
          - -log-format=glog
          - -nginx-status=true
          - -nginx-status-port=10246
          - -nginx-status-allow-cidrs=127.0.0.1
          - -report-ingress-status
          - -external-service=wallarm-existing-secret-wallarm-ingress-controller
          - -enable-leader-election=true
          - -leader-election-lock-name=wallarm-existing-secret-wallarm-ingress-leader-election
          - -enable-prometheus-metrics=true
          - -prometheus-metrics-listen-port=9113
          - -prometheus-tls-secret=
          - -enable-custom-resources=true
          - -enable-snippets=false
          - -disable-ipv6=false
          - -enable-tls-passthrough=false
          - -enable-cert-manager=false
          - -enable-external-dns=false
          - -default-http-listener-port=80
          - -default-https-listener-port=443
          - -ready-status=true
          - -ready-status-port=8081
          - -enable-latency-metrics=false
          - -ssl-dynamic-reload=true
          - -enable-telemetry-reporting=false
      - name: wcli
        image: docker.io/wallarm/node-helpers:APP_VERSION
        imagePullPolicy: IfNotPresent
        args: ["wcli", "run", "-log-level", "WARN", "job:apispec", "-log-level", "INFO", "job:envexp", "-log-level", "INFO", "job:ipfeed", "-log-level", "INFO", "job:iplist", "-log-level", "INFO", "job:metricsexp", "-log-level", "INFO", "job:register", "-log-level", "INFO", "job:syncnode", "-log-level", "INFO"]
        env:
        - name: WALLARM_API_HOST
          value: "api.wallarm.com"
        - name: WALLARM_API_PORT
          value: "443"
        - name: WALLARM_API_USE_SSL
          value: "true"
        - name: WALLARM_API_TOKEN_PATH
          value: "/secrets/wallarm/token"
        - name: WALLARM_COMPONENT_NAME
          value: wallarm-new-ingress-controller
        - name: WALLARM_COMPONENT_VERSION
          value: "CHART_VERSION"
        - name: WALLARM_NODE_NAME
          valueFrom:
            fieldRef:
              fieldPath: metadata.name
        - name: WALLARM_WCLI__METRICS__LISTEN_ADDRESS
          value: ":9004"
        ports:
        - name: wcli-ctrl-mtrc
          containerPort: 9004
          protocol: TCP
        volumeMounts:
        - mountPath: /opt/wallarm/etc/wallarm
          name: wallarm
        - mountPath: /opt/wallarm/var/lib/wallarm-acl
          name: wallarm-acl
        - mountPath: /secrets/wallarm/token
          name: wallarm-token
          subPath: token
          readOnly: true
        - mountPath: /opt/wallarm/var/lib/wallarm-api
          name: wallarm-apifw
        
        securityContext:
          allowPrivilegeEscalation: false
          readOnlyRootFilesystem: false
          runAsUser: 101 #nginx
          runAsNonRoot: true
          capabilities:
            drop:
            - ALL
            add:
            - NET_BIND_SERVICE

      - name: api-firewall
        image: docker.io/wallarm/node-helpers:APP_VERSION
        imagePullPolicy: IfNotPresent
        args: ["api-firewall"]
        env:
          - name: APIFW_SPECIFICATION_UPDATE_PERIOD
            value: "1m"
          - name: API_MODE_UNKNOWN_PARAMETERS_DETECTION
            value: "true"
          - name: APIFW_URL
            value: "http://0.0.0.0:18081"
          - name: APIFW_HEALTH_HOST
            value: "0.0.0.0:18082"
          - name: APIFW_LOG_LEVEL
            value: "INFO"
          - name: APIFW_LOG_FORMAT
            value: "TEXT"
          - name: APIFW_MODE
            value: api
          - name: APIFW_READ_TIMEOUT
            value: 5s
          - name: APIFW_WRITE_TIMEOUT
            value: 5s
          - name: APIFW_READ_BUFFER_SIZE
            value: "8192"
          - name: APIFW_WRITE_BUFFER_SIZE
            value: "8192"
          - name: APIFW_MAX_REQUEST_BODY_SIZE
            value: "4194304"
          - name: APIFW_DISABLE_KEEPALIVE
            value: "false"
          - name: APIFW_MAX_CONNS_PER_IP
            value: "0"
          - name: APIFW_MAX_REQUESTS_PER_CONN
            value: "0"
          - name: APIFW_API_MODE_MAX_ERRORS_IN_RESPONSE
            value: "3"
          - name: APIFW_API_MODE_DEBUG_PATH_DB
            value: "/opt/wallarm/var/lib/wallarm-api/3/wallarm_api.db"
          - name: APIFW_METRICS_ENABLED
            value: "false"
        ports:
        - name: apifw-health
          containerPort: 18082
          protocol: TCP
        volumeMounts:
        - name: wallarm-apifw
          mountPath: /opt/wallarm/var/lib/wallarm-api
        
        securityContext:
          allowPrivilegeEscalation: false
          readOnlyRootFilesystem: false
          runAsUser: 101 #nginx
          runAsNonRoot: true
          capabilities:
            drop:
            - ALL
            add:
            - NET_BIND_SERVICE
      initContainers:
      
      - name: wallarm-init
        image: docker.io/wallarm/node-helpers:APP_VERSION
        imagePullPolicy: IfNotPresent
        args: [ "register", "filtering", "fallback" ]
        env:
        - name: WALLARM_API_HOST
          value: "api.wallarm.com"
        - name: WALLARM_API_PORT
          value: "443"
        - name: WALLARM_API_USE_SSL
          value: "true"
        - name: WALLARM_API_TOKEN_PATH
          value: "/secrets/wallarm/token"
        - name: WALLARM_COMPONENT_NAME
          value: wallarm-new-ingress-controller
        - name: WALLARM_COMPONENT_VERSION
          value: "CHART_VERSION"
        - name: WALLARM_NODE_NAME
          valueFrom:
            fieldRef:
              fieldPath: metadata.name
        - name: WALLARM_SYNCNODE_OWNER
          value: www-data
        - name: WALLARM_SYNCNODE_GROUP
          value: www-data
        - name: WALLARM_LABELS
          value: "group=defaultIngressGroup"
        volumeMounts:
        - mountPath: /opt/wallarm/etc/wallarm
          name: wallarm
        - mountPath: /opt/wallarm/var/lib/wallarm-acl
          name: wallarm-acl
        - mountPath: /opt/wallarm/var/lib/wallarm-api
          name: wallarm-apifw
        - mountPath: /secrets/wallarm/token
          name: wallarm-token
          subPath: token
          readOnly: true
        
        securityContext:
          allowPrivilegeEscalation: false
          readOnlyRootFilesystem: false
          runAsUser: 101 #nginx
          runAsNonRoot: true
          capabilities:
            drop:
            - ALL
            add:
            - NET_BIND_SERVICE
