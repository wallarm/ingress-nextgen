  type: LoadBalancer
  ports:
  - port: 80
    targetPort: 80
    protocol: TCP
    name: http
    nodePort: 
  - port: 443
    targetPort: 443
    protocol: TCP
    name: https
    nodePort: 
  selector:
    app.kubernetes.io/name: wallarm-ingress-new
    app.kubernetes.io/instance: app-protect-waf-agentv2
    app.kubernetes.io/component: controller
