apiVersion: v1
kind: Service
metadata:
  name: app-protect-wafv5-agentv2-wallarm-ingress-controller
  namespace: default
  labels:
    helm.sh/chart: wallarm-ingress-CHART_VERSION
    app.kubernetes.io/name: wallarm-ingress
    app.kubernetes.io/instance: app-protect-wafv5-agentv2
    app.kubernetes.io/version: "APP_VERSION"
