apiVersion: v1
kind: Service
metadata:
  name: global-config-custom-name-wallarm-ingress-controller
  namespace: default
  labels:
    helm.sh/chart: wallarm-ingress-CHART_VERSION
    app.kubernetes.io/name: wallarm-ingress
    app.kubernetes.io/instance: global-config-custom-name
    app.kubernetes.io/version: "APP_VERSION"
    app.kubernetes.io/managed-by: Helm
    app.kubernetes.io/component: controller
spec:
  externalTrafficPolicy: Local
  type: LoadBalancer
  ports:
  - port: 80
    targetPort: 80
    protocol: TCP
    name: http
    nodePort: 
  - port: 443
    targetPort: 443
    protocol: TCP
    name: https
    nodePort: 
  selector:
    app.kubernetes.io/name: wallarm-ingress
    app.kubernetes.io/instance: global-config-custom-name
    app.kubernetes.io/component: controller
