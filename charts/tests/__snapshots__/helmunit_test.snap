# Source: wallarm-ingress-new/templates/controller-deployment.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: app-protect-waf-agentv2-wallarm-ingress-new-controller
  namespace: default
  labels:
    helm.sh/chart: wallarm-ingress-new-7.0.0
    app.kubernetes.io/name: wallarm-ingress-new
    app.kubernetes.io/instance: app-protect-waf-agentv2
    app.kubernetes.io/version: "6.7.5"
    app.kubernetes.io/managed-by: Helm
    app.kubernetes.io/component: controller
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: wallarm-ingress-new
      app.kubernetes.io/instance: app-protect-waf-agentv2
      app.kubernetes.io/component: controller
  template:
    metadata:
      labels:
        app.kubernetes.io/name: wallarm-ingress-new
        app.kubernetes.io/instance: app-protect-waf-agentv2
        app.kubernetes.io/component: controller
      annotations:
        prometheus.io/scrape: "true"
        prometheus.io/port: "9113"
        prometheus.io/scheme: "http"
    spec:      
      volumes: []
      serviceAccountName: app-protect-waf-agentv2-wallarm-ingress-new
      automountServiceAccountToken: true
      securityContext:
        seccompProfile:
          type: RuntimeDefault
      terminationGracePeriodSeconds: 30
      hostNetwork: false
      dnsPolicy: ClusterFirst
      containers:
      - image: docker.io/wallarm/nginx-node-ic:0.0.1
        name: wallarm-ingress-new
        imagePullPolicy: "IfNotPresent"
        ports:
        - name: http
          containerPort: 80
          protocol: TCP
        - name: https
          containerPort: 443
          protocol: TCP
        - name: prometheus
          containerPort: 9113
        - name: readiness-port
          containerPort: 8081
        readinessProbe:
          httpGet:
            path: /nginx-ready
            port: readiness-port
          periodSeconds: 1
          initialDelaySeconds: 0
        resources:
          requests:
            cpu: 100m
            memory: 128Mi
        securityContext:
          allowPrivilegeEscalation: false
          readOnlyRootFilesystem: false
          runAsUser: 101 #nginx
          runAsNonRoot: true
          capabilities:
            drop:
            - ALL
            add:
            - NET_BIND_SERVICE        
        volumeMounts: []
        env:
        - name: POD_NAMESPACE
          valueFrom:
            fieldRef:
              fieldPath: metadata.namespace
        - name: POD_NAME
          valueFrom:
            fieldRef:
              fieldPath: metadata.name
        args:
          
          - -nginx-reload-timeout=60000
          - -nginx-configmaps=$(POD_NAMESPACE)/app-protect-waf-agentv2-wallarm-ingress-new
          - -ingress-class=nginx
          - -health-status=false
          - -health-status-uri=/nginx-health
          - -nginx-debug=false
          - -log-level=info
          - -log-format=glog
          - -nginx-status=true
          - -nginx-status-port=10246
          - -nginx-status-allow-cidrs=127.0.0.1
          - -report-ingress-status
          - -external-service=app-protect-waf-agentv2-wallarm-ingress-new-controller
          - -enable-leader-election=true
          - -leader-election-lock-name=app-protect-waf-agentv2-wallarm-ingress-new-leader-election
          - -enable-prometheus-metrics=true
          - -prometheus-metrics-listen-port=9113
          - -prometheus-tls-secret=
          - -enable-custom-resources=true
          - -enable-snippets=false
          - -disable-ipv6=false
          - -enable-tls-passthrough=false
          - -enable-cert-manager=false
          - -enable-external-dns=false
          - -default-http-listener-port=80
          - -default-https-listener-port=443
          - -ready-status=true
          - -ready-status-port=8081
          - -enable-latency-metrics=false
          - -ssl-dynamic-reload=true
          - -enable-telemetry-reporting=false
/-/-/-/
